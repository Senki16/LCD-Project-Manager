# Copia este archivo como .env

# ── Base de datos ──────────────────────────────────────────────
# Local (desarrollo escritorio): SQLite
# DATABASE_URL="file:./lcd_projects.db"
# Nube (Supabase Postgres) — usa el "Session pooler" del dashboard:
DATABASE_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres"

PORT=3001

# ── Almacenamiento de archivos en la nube (Supabase Storage) ──
# Si están definidas, los archivos se suben a Supabase; si no, se usan en disco local.
SUPABASE_URL="https://[REF].supabase.co"
SUPABASE_SERVICE_KEY="<service_role key del dashboard → Settings → API>"
SUPABASE_BUCKET="project-files"

# ── CORS (solo si usas dominio propio; *.vercel.app y localhost ya están permitidos) ──
# FRONTEND_URL="https://midominio.com"
